<NMSMPipelineDocument Version="1.4.0">
	<TrackingOptimizationTool name="default">
		<!--Directory used for writing results.-->
		<results_directory>TOResults</results_directory>
		<!--Directory for optimizer initial guess.-->
		<initial_guess_directory>..\NeuralControlPersonalization\NCPResultsBilateral</initial_guess_directory>
		<!--Directory for files for the optimizer to track.-->
		<tracked_quantities_directory>..\preprocessing\preprocessed</tracked_quantities_directory>
		<!--Name of the input model file (.osim) to use.-->
		<input_model_file>..\UF_Subject_4_Scaled_JMP.osim</input_model_file>
		<!--Name of the osimx model file.-->
		<input_osimx_file>..\NeuralControlPersonalization\NCPResultsBilateral\UF_Subject_4_Scaled_JMP_gcp_mtp_mtp_ncp.osimx</input_osimx_file>
		<!--Name of the optimal control solver settings file.-->
		<optimal_control_solver_settings_file>..\gpopsSettings.xml</optimal_control_solver_settings_file>
		<!--Name, excluding file type (.sto, .mot, etc), of the trial-->
		<trial_name>gait_1</trial_name>
		<!--Space separated list of coordinates to be considered GPOPS2 states. Not including a coordinate prescribes it.-->
		<states_coordinate_list>pelvis_tilt pelvis_list pelvis_rotation pelvis_tx pelvis_ty pelvis_tz hip_flexion_r hip_adduction_r hip_rotation_r knee_angle_r ankle_angle_r subtalar_angle_r mtp_angle_r hip_flexion_l hip_adduction_l hip_rotation_l knee_angle_l ankle_angle_l subtalar_angle_l mtp_angle_l lumbar_extension lumbar_bending lumbar_rotation arm_flex_r arm_add_r arm_rot_r elbow_flex_r arm_flex_l arm_add_l arm_rot_l elbow_flex_l</states_coordinate_list>
		<!--*Optional* Default is 2.-->
		<joint_position_range_scale_factor>1.5</joint_position_range_scale_factor>
		<!--*Optional* Default is 1.5.-->
		<joint_velocity_range_scale_factor>1.25</joint_velocity_range_scale_factor>
		<!--*Optional* Default is 1.-->
		<joint_acceleration_range_scale_factor>1</joint_acceleration_range_scale_factor>
		<!--load_surrogate_model>true</load_surrogate_model-->
		
		<save_surrogate_model>false</save_surrogate_model>
		<normalize_cost_by_term_type>false</normalize_cost_by_term_type>
		<!--Set of synergy controls for GPOPS2.-->
		<RCNLSynergyController>
			<!--Boolean (true, false) indicating if synergy vectors should be optimized.-->
			<optimize_synergy_vectors>true</optimize_synergy_vectors>
			<load_surrogate_model>true</load_surrogate_model>
			<!--Space separated list containing the coordinates controlled by the synergy controller.-->
			<surrogate_model_coordinate_list>hip_flexion_r hip_adduction_r hip_rotation_r knee_angle_r ankle_angle_r subtalar_angle_r mtp_angle_r hip_flexion_l hip_adduction_l hip_rotation_l knee_angle_l ankle_angle_l subtalar_angle_l mtp_angle_l</surrogate_model_coordinate_list>
			<!--Directory to read the surrogate model from.-->
			<surrogate_model_data_directory>surrogateData</surrogate_model_data_directory>
		</RCNLSynergyController>
		<!--Set of cost terms used for this optimization. For a full list of cost terms, see documentation at nmsm.rice.edu.-->
		<RCNLCostTermSet>
			<RCNLCostTerm name="lower limb coordinate tracking big">
				<!--Indicate whether the term is enabled or not. Default is false.-->
				<is_enabled>true</is_enabled>
				<!--Type of cost term.-->
				<type>generalized_coordinate_tracking</type>
				<!--Space separated list containing model coordinates to be included in this cost term.-->
				<coordinate_list>hip_flexion_r knee_angle_r ankle_angle_r hip_flexion_l knee_angle_l ankle_angle_l </coordinate_list>
				<!--The accuracy to compare against, depends on model/data units (0.01 == 1cm for data in units meters).-->
				<max_allowable_error>0.15</max_allowable_error>
			</RCNLCostTerm>
			<RCNLCostTerm name="lower limb coordinate tracking small">
				<!--Indicate whether the term is enabled or not. Default is false.-->
				<is_enabled>true</is_enabled>
				<!--Type of cost term.-->
				<type>generalized_coordinate_tracking</type>
				<!--Space separated list containing model coordinates to be included in this cost term.-->
				<coordinate_list>hip_adduction_r hip_rotation_r subtalar_angle_r mtp_angle_r hip_adduction_l hip_rotation_l subtalar_angle_l mtp_angle_l</coordinate_list>
				<!--The accuracy to compare against, depends on model/data units (0.01 == 1cm for data in units meters).-->
				<max_allowable_error>0.05</max_allowable_error>
			</RCNLCostTerm>
			<RCNLCostTerm name="upper limb coordinate tracking small">
				<!--Indicate whether the term is enabled or not. Default is false.-->
				<is_enabled>true</is_enabled>
				<!--Type of cost term.-->
				<type>generalized_coordinate_tracking</type>
				<!--Space separated list containing model coordinates to be included in this cost term.-->
				<coordinate_list>lumbar_extension lumbar_bending lumbar_rotation arm_flex_r arm_add_r arm_rot_r elbow_flex_r arm_flex_l arm_add_l arm_rot_l elbow_flex_l</coordinate_list>
				<!--The accuracy to compare against, depends on model/data units (0.01 == 1cm for data in units meters).-->
				<max_allowable_error>0.15</max_allowable_error>
			</RCNLCostTerm>
			<RCNLCostTerm name="ID load tracking">
				<!--Indicate whether the term is enabled or not. Default is false.-->
				<is_enabled>true</is_enabled>
				<!--Type of cost term.-->
				<type>inverse_dynamics_load_tracking</type>
				<!--Space separated list containing model loads to be included in this cost term.-->
				<load_list>hip_flexion_r_moment hip_adduction_r_moment hip_rotation_r_moment knee_angle_r_moment ankle_angle_r_moment subtalar_angle_r_moment hip_flexion_l_moment hip_adduction_l_moment hip_rotation_l_moment knee_angle_l_moment ankle_angle_l_moment subtalar_angle_l_moment</load_list>
				<!--The accuracy to compare against, depends on model/data units (0.01 == 1cm for data in units meters).-->
				<max_allowable_error>15</max_allowable_error>
			</RCNLCostTerm>
			<RCNLCostTerm name="Speed tracking">
				<!--Indicate whether the term is enabled or not. Default is false.-->
				<is_enabled>true</is_enabled>
				<!--Type of cost term.-->
				<type>generalized_speed_tracking</type>
				<!--Space separated list containing model coordinates to be included in this cost term.-->
				<coordinate_list>pelvis_tilt pelvis_list pelvis_rotation pelvis_tx pelvis_tz hip_flexion_r hip_adduction_r hip_rotation_r knee_angle_r ankle_angle_r subtalar_angle_r mtp_angle_r hip_flexion_l hip_adduction_l hip_rotation_l knee_angle_l ankle_angle_l subtalar_angle_l mtp_angle_l lumbar_extension lumbar_bending lumbar_rotation arm_flex_r arm_add_r arm_rot_r elbow_flex_r arm_flex_l arm_add_l arm_rot_l elbow_flex_l</coordinate_list>
				<!--The accuracy to compare against, depends on model/data units (0.01 == 1cm for data in units meters).-->
				<max_allowable_error>2</max_allowable_error>
			</RCNLCostTerm>
			<RCNLCostTerm name="Pelvis translation tracking">
				<!--Indicate whether the term is enabled or not. Default is false.-->
				<is_enabled>true</is_enabled>
				<!--Type of cost term.-->
				<type>generalized_coordinate_tracking</type>
				<!--Space separated list containing model coordinates to be included in this cost term.-->
				<coordinate_list>pelvis_tx pelvis_tz</coordinate_list>
				<!--The accuracy to compare against, depends on model/data units (0.01 == 1cm for data in units meters).-->
				<max_allowable_error>0.010000000000000001</max_allowable_error>
			</RCNLCostTerm>
			<RCNLCostTerm name="pelvis rotation tracking">
				<!--Indicate whether the term is enabled or not. Default is false.-->
				<is_enabled>true</is_enabled>
				<!--Type of cost term.-->
				<type>generalized_coordinate_tracking</type>
				<!--Space separated list containing model coordinates to be included in this cost term.-->
				<coordinate_list>pelvis_tilt pelvis_list pelvis_rotation</coordinate_list>
				<!--The accuracy to compare against, depends on model/data units (0.01 == 1cm for data in units meters).-->
				<max_allowable_error>0.05</max_allowable_error>
			</RCNLCostTerm>
			<RCNLCostTerm name="Vertical external force tracking">
				<!--Indicate whether the term is enabled or not. Default is false.-->
				<is_enabled>true</is_enabled>
				<!--Type of cost term.-->
				<type>external_force_tracking</type>
				<!--Space separated list containing external forces to be included in this cost term.-->
				<force_list>ground_force_2_vy ground_force_1_vy</force_list>
				<!--The accuracy to compare against, depends on model/data units (0.01 == 1cm for data in units meters).-->
				<max_allowable_error>50</max_allowable_error>
			</RCNLCostTerm>
			<RCNLCostTerm name="horizontal external force tracking">
				<!--Indicate whether the term is enabled or not. Default is false.-->
				<is_enabled>true</is_enabled>
				<!--Type of cost term.-->
				<type>external_force_tracking</type>
				<!--Space separated list containing external forces to be included in this cost term.-->
				<force_list>ground_force_2_vx ground_force_2_vz ground_force_1_vx ground_force_1_vz</force_list>
				<!--The accuracy to compare against, depends on model/data units (0.01 == 1cm for data in units meters).-->
				<max_allowable_error>5</max_allowable_error>
			</RCNLCostTerm>
			<RCNLCostTerm name="External moment tracking">
				<!--Indicate whether the term is enabled or not. Default is false.-->
				<is_enabled>true</is_enabled>
				<!--Type of cost term.-->
				<type>external_moment_tracking</type>
				<!--Space separated list containing external moments to be included in this cost term.-->
				<moment_list>ground_moment_2_my ground_moment_2_mz ground_moment_1_my ground_moment_1_mz</moment_list>
				<!--The accuracy to compare against, depends on model/data units (0.01 == 1cm for data in units meters).-->
				<max_allowable_error>10</max_allowable_error>
			</RCNLCostTerm>
			<RCNLCostTerm name="X moment tracking">
				<!--Indicate whether the term is enabled or not. Default is false.-->
				<is_enabled>true</is_enabled>
				<!--Type of cost term.-->
				<type>external_moment_tracking</type>
				<!--Space separated list containing external moments to be included in this cost term.-->
				<moment_list>ground_moment_2_mx ground_moment_1_mx </moment_list>
				<!--The accuracy to compare against, depends on model/data units (0.01 == 1cm for data in units meters).-->
				<max_allowable_error>10</max_allowable_error>
			</RCNLCostTerm>
			<RCNLCostTerm name="Muscle activation tracking">
				<!--Indicate whether the term is enabled or not. Default is false.-->
				<is_enabled>true</is_enabled>
				<!--Type of cost term.-->
				<type>muscle_activation_tracking</type>
				<!--Space separated list containing muscles to be included in this cost term.-->
				<muscle_list>addbrev_r addlong_r addmagDist_r addmagIsch_r addmagMid_r addmagProx_r bflh_r bfsh_r edl_r ehl_r fdl_r fhl_r gaslat_r gasmed_r gem_r glmax1_r glmax2_r glmax3_r glmed1_r glmed2_r glmed3_r glmin1_r glmin2_r glmin3_r grac_r iliacus_r pect_r perbrev_r perlong_r piri_r psoas_r quadfem_r recfem_r sart_r semimem_r semiten_r soleus_r tfl_r tibant_r tibpost_r vasint_r vaslat_r vasmed_r addbrev_l addlong_l addmagDist_l addmagIsch_l addmagMid_l addmagProx_l bflh_l bfsh_l edl_l ehl_l fdl_l fhl_l gaslat_l gasmed_l gem_l glmax1_l glmax2_l glmax3_l glmed1_l glmed2_l glmed3_l glmin1_l glmin2_l glmin3_l grac_l iliacus_l pect_l perbrev_l perlong_l piri_l psoas_l quadfem_l recfem_l sart_l semimem_l semiten_l soleus_l tfl_l tibant_l tibpost_l vasint_l vaslat_l vasmed_l</muscle_list>
				<!--The accuracy to compare against, depends on model/data units (0.01 == 1cm for data in units meters).-->
				<max_allowable_error>0.1</max_allowable_error>
			</RCNLCostTerm>
			<RCNLCostTerm name="Synergy activation tracking">
				<!--Indicate whether the term is enabled or not. Default is false.-->
				<is_enabled>true</is_enabled>
				<!--Type of cost term.-->
				<type>controller_tracking</type>
				<!--Space separated list containing muscles to be included in this cost term.-->
				<controller_list>right_leg_1 right_leg_2 right_leg_3 right_leg_4 right_leg_5 left_leg_1 left_leg_2 left_leg_3 left_leg_4 left_leg_5</controller_list>
				<!--The accuracy to compare against, depends on model/data units (0.01 == 1cm for data in units meters).-->
				<max_allowable_error>0.25</max_allowable_error>
			</RCNLCostTerm>
			<RCNLCostTerm name="synergy_vector_tracking">
				<is_enabled>true</is_enabled>
				<type>synergy_vector_tracking</type>
				<synergy_list>right_leg_1 right_leg_2 right_leg_3 right_leg_4 right_leg_5 left_leg_1 left_leg_2 left_leg_3 left_leg_4 left_leg_5</synergy_list>
				<max_allowable_error>1</max_allowable_error>
			</RCNLCostTerm>
		</RCNLCostTermSet>
		<!--Set of constraint terms applied to this optimization. For a full list of constraint terms, see documentation at nmsm.rice.edu.-->
		<RCNLConstraintTermSet>
			<RCNLConstraintTerm name="kinetic consistency">
				<!--Flag (true, false) indicating whether this contraint term is enabled. Default is false.-->
				<is_enabled>true</is_enabled>
				<!--Type of constraint term.-->
				<type>kinetic_consistency</type>
				<!--Space separated list containing model loads to be included in this cost term.-->
				<load_list>hip_flexion_r_moment hip_adduction_r_moment hip_rotation_r_moment knee_angle_r_moment ankle_angle_r_moment subtalar_angle_r_moment hip_flexion_l_moment hip_adduction_l_moment hip_rotation_l_moment knee_angle_l_moment ankle_angle_l_moment subtalar_angle_l_moment</load_list>
				<!--Maximum error allowed by this constraint term.-->
				<max_error>0.010000000000000001</max_error>
				<!--Minimum error allowed by this constraint term.-->
				<min_error>-0.010000000000000001</min_error>
			</RCNLConstraintTerm>
			<RCNLConstraintTerm name="Residual force reduction">
				<!--Flag (true, false) indicating whether this contraint term is enabled. Default is false.-->
				<is_enabled>true</is_enabled>
				<!--Type of constraint term.-->
				<type>root_segment_residual_load</type>
				<!--Space separated list containing model coordinates to be included in this cost term.-->
				<load_list>pelvis_tx_force pelvis_ty_force pelvis_tz_force</load_list>
				<!--Maximum error allowed by this constraint term.-->
				<max_error>1</max_error>
				<!--Minimum error allowed by this constraint term.-->
				<min_error>-1</min_error>
			</RCNLConstraintTerm>
			<RCNLConstraintTerm name="residual moment reduction">
				<!--Flag (true, false) indicating whether this contraint term is enabled. Default is false.-->
				<is_enabled>true</is_enabled>
				<!--Type of constraint term.-->
				<type>root_segment_residual_load</type>
				<!--Space separated list containing model loads to be included in this cost term.-->
				<load_list>pelvis_tilt_moment pelvis_list_moment pelvis_rotation_moment</load_list>
				<!--Maximum error allowed by this constraint term.-->
				<max_error>0.1</max_error>
				<!--Minimum error allowed by this constraint term.-->
				<min_error>-0.1</min_error>
			</RCNLConstraintTerm>
			<RCNLConstraintTerm name="rotational coordinate periodicity">
				<!--Flag (true, false) indicating whether this contraint term is enabled. Default is false.-->
				<is_enabled>true</is_enabled>
				<!--Type of constraint term.-->
				<type>generalized_coordinate_periodicity</type>
				<!--Space separated list containing model coordinates to be included in this cost term.-->
				<coordinate_list>pelvis_tilt pelvis_list pelvis_rotation hip_flexion_r hip_adduction_r hip_rotation_r knee_angle_r ankle_angle_r subtalar_angle_r mtp_angle_r hip_flexion_l hip_adduction_l hip_rotation_l knee_angle_l ankle_angle_l subtalar_angle_l mtp_angle_l lumbar_extension lumbar_bending lumbar_rotation arm_flex_r arm_add_r arm_rot_r elbow_flex_r arm_flex_l arm_add_l arm_rot_l elbow_flex_l</coordinate_list>
				<!--Maximum error allowed by this constraint term.-->
				<max_error>0.010000000000000001</max_error>
				<!--Minimum error allowed by this constraint term.-->
				<min_error>-0.010000000000000001</min_error>
			</RCNLConstraintTerm>
			<RCNLConstraintTerm name="translational coordinate periodicity">
				<!--Flag (true, false) indicating whether this contraint term is enabled. Default is false.-->
				<is_enabled>true</is_enabled>
				<!--Type of constraint term.-->
				<type>generalized_coordinate_periodicity</type>
				<!--Space separated list containing model coordinates to be included in this cost term.-->
				<coordinate_list>pelvis_tx pelvis_ty pelvis_tz</coordinate_list>
				<!--Maximum error allowed by this constraint term.-->
				<max_error>0.01</max_error>
				<!--Minimum error allowed by this constraint term.-->
				<min_error>-0.01</min_error>
			</RCNLConstraintTerm>
			<RCNLConstraintTerm name="External force periodicity">
				<!--Flag (true, false) indicating whether this contraint term is enabled. Default is false.-->
				<is_enabled>true</is_enabled>
				<!--Type of constraint term.-->
				<type>external_force_periodicity</type>
				<!--Space separated list containing external forces to be included in this cost term.-->
				<force_list>ground_force_2_vx ground_force_2_vy ground_force_2_vz ground_force_1_vx ground_force_1_vy ground_force_1_vz</force_list>
				<!--Maximum error allowed by this constraint term.-->
				<max_error>5</max_error>
				<!--Minimum error allowed by this constraint term.-->
				<min_error>-5</min_error>
			</RCNLConstraintTerm>
			<RCNLConstraintTerm name="external moment periodicity">
				<!--Flag (true, false) indicating whether this contraint term is enabled. Default is false.-->
				<is_enabled>true</is_enabled>
				<!--Type of constraint term.-->
				<type>external_moment_periodicity</type>
				<!--Space separated list containing external moments to be included in this cost term.-->
				<moment_list>ground_moment_2_mx ground_moment_2_my ground_moment_2_mz ground_moment_1_mx ground_moment_1_my ground_moment_1_mz</moment_list>
				<!--Maximum error allowed by this constraint term.-->
				<max_error>1</max_error>
				<!--Minimum error allowed by this constraint term.-->
				<min_error>-1</min_error>
			</RCNLConstraintTerm>
			<RCNLConstraintTerm name="Rotational speed periodicity">
				<!--Flag (true, false) indicating whether this contraint term is enabled. Default is false.-->
				<is_enabled>true</is_enabled>
				<!--Type of constraint term.-->
				<type>generalized_speed_periodicity</type>
				<!--Space separated list containing model coordinates to be included in this cost term.-->
				<coordinate_list>pelvis_tilt pelvis_list pelvis_rotation hip_flexion_r hip_adduction_r hip_rotation_r knee_angle_r ankle_angle_r subtalar_angle_r mtp_angle_r hip_flexion_l hip_adduction_l hip_rotation_l knee_angle_l ankle_angle_l subtalar_angle_l mtp_angle_l lumbar_extension lumbar_bending lumbar_rotation arm_flex_r arm_add_r arm_rot_r elbow_flex_r arm_flex_l arm_add_l arm_rot_l elbow_flex_l</coordinate_list>
				<!--Maximum error allowed by this constraint term.-->
				<max_error>0.10000000000000001</max_error>
				<!--Minimum error allowed by this constraint term.-->
				<min_error>-0.10000000000000001</min_error>
			</RCNLConstraintTerm>
			<RCNLConstraintTerm name="translational speed periodicity">
				<!--Flag (true, false) indicating whether this contraint term is enabled. Default is false.-->
				<is_enabled>true</is_enabled>
				<!--Type of constraint term.-->
				<type>generalized_speed_periodicity</type>
				<!--Space separated list containing model coordinates to be included in this cost term.-->
				<coordinate_list>pelvis_tx pelvis_ty pelvis_tz</coordinate_list>
				<!--Maximum error allowed by this constraint term.-->
				<max_error>0.01</max_error>
				<!--Minimum error allowed by this constraint term.-->
				<min_error>-0.01</min_error>
			</RCNLConstraintTerm>
			<RCNLConstraintTerm name="translational speed periodicity">
				<!--Flag (true, false) indicating whether this contraint term is enabled. Default is false.-->
				<is_enabled>false</is_enabled>
				<!--Type of constraint term.-->
				<type>marker_position_periodicity</type>
				<!--Space separated list containing model coordinates to be included in this cost term.-->
				<marker_list>R_Heel L_Heel</marker_list>
				<axes>x y z</axes>
				<!--Maximum error allowed by this constraint term.-->
				<max_error>0.01</max_error>
				<!--Minimum error allowed by this constraint term.-->
				<min_error>-0.01</min_error>
			</RCNLConstraintTerm>
		</RCNLConstraintTermSet>
	</TrackingOptimizationTool>
